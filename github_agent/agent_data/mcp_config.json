{
  "mcpServers": {
    "github-mcp": {
      "command": "github-mcp",
      "args": [
        "--transport",
        "stdio"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "CONTENTSTOOL": "${ CONTENTSTOOL:-True }",
        "ISSUETOOL": "${ ISSUETOOL:-True }",
        "PULLSTOOL": "${ PULLSTOOL:-True }",
        "REPOSTOOL": "${ REPOSTOOL:-True }"
      }
    }
  }
}

{
  "mcpServers": {
    "github-agent": {
      "command": "uv",
      "args": [
        "run",
        "github-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "ACTIONTOOL": "True",
        "BRANCHTOOL": "True",
        "COLLABORATORTOOL": "True",
        "COMMITTOOL": "True",
        "CONTENTTOOL": "True",
        "GITHUB_ALLOW_DESTRUCTIVE": "False",
        "GITHUB_HTTP_CONNECT_TIMEOUT": "10",
        "GITHUB_HTTP_READ_TIMEOUT": "30",
        "GITHUB_TOKEN": "your_github_token_here",
        "GITHUB_URL": "https://api.github.com",
        "GITHUB_VERIFY": "True",
        "GRAPHQLTOOL": "True",
        "INGESTTOOL": "True",
        "ISSUETOOL": "True",
        "ORGTOOL": "True",
        "PULLTOOL": "True",
        "RELEASETOOL": "True",
        "REPOTOOL": "True",
        "SEARCHTOOL": "True"
      }
    }
  }
}
